<!DOCTYPE html>
<html lang="en">
<head>
  <meta name="Miguel Cedrick B. Yague" content="Miguel Cedrick B. Yague, Rafael Kendrick B. Yague" />
  <meta name="Miguel Cedrick B. Yague" content="March 31, 2026" />
  
  <style>
    body { 
      font-family: Arial, sans-serif; 
      height: 2000px; /* Added height to test Step 2 (Fixed) scrolling */
    }

    .header, .footer {
      background: lightblue;
      padding: 10px;
    }

    .footer {
      opacity: 0.5;
      /* Step 2: Fixed Positioning */
      position: fixed; 
      bottom: 0; 
      width: 100%;
    }

    .sidebar {
      background: lightgreen;
      width: 150px;
      height: 200px;
      /* Step 1: Relative Positioning */
      position: relative; 
      top: 20px; 
      left: 20px;
    }

    .content {
      background: lightyellow;
      width: 300px;
      height: 200px;
      /* Step 3 & Challenge: Absolute and Relative */
      position: absolute; 
      top: 66px; 
      left: 200px;
      z-index: 1;
    }


    
    .notice {
      position: absolute;
      top: 0;
      right: 0;
      background: orange;
      padding: 10px;
      z-index: 2;
    }
  </style>
</head>
<body>

  <div class="header">Header</div>

  <div class="sidebar">Sidebar</div>

  <div class="content">
    Main Content
    <div class="notice">Notice!</div>
  </div>

  <div class="footer">Footer (Stays at the bottom when you scroll)</div>

</body>
</html>
